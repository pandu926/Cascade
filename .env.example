# Cascade Configuration
# Copy to .env (gitignored) and fill in real values. NEVER commit the real .env.

# ─── SDK (Node.js) ───────────────────────────────────────────────────────────
# Private key for SDK operations (with or without 0x prefix)
CASCADE_PRIVATE_KEY=0x...

# Network: "mainnet" or "testnet" (default: mainnet)
CASCADE_NETWORK=mainnet

# ─── Foundry Scripts ─────────────────────────────────────────────────────────
# Signing key for broadcast scripts (funded throwaway testnet wallet).
# Read via vm.envUint("PRIVATE_KEY"); never logged by any script.
PRIVATE_KEY=

# Target RPC. Scripts resolve the network via the `--rpc-url` flag, which may be a
# foundry.toml rpc_endpoints alias (atlantic_testnet | mainnet) or a full URL.
RPC_URL=https://atlantic.dplabs-internal.com

# Deployed Cascade address (set after running Deploy.s.sol).
CASCADE=

# --- Register.s.sol ---
# Invoke price in wei (0 allowed for a leaf skill).
PRICE=
# Comma-separated dependency ids and their bps shares (aligned 1:1). Leave blank for a leaf.
DEP_IDS=
DEP_SHARES=

# --- Invoke.s.sol ---
SKILL_ID=
# Exact wei to send; must equal the skill's registered price.
INVOKE_VALUE=

# --- DemoTree.s.sol (optional) ---
# Distinct creator keys for the A->B->C demo. If unset, deterministic demo defaults
# are used (suitable for local runs / forge simulation only — never for mainnet).
CREATOR_A_KEY=
CREATOR_B_KEY=
CREATOR_C_KEY=
